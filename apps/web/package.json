{
  "name": "web",
  "version": "beta3.0.1",
  "private": true,
  "license": "CC BY-NC-SA 4.0",
  "scripts": {
    "dev": "NEXT_PUBLIC_ENABLE_SOCKET=true next dev",
    "build": "next build",
    "start": "NODE_ENV=production node server.js || NODE_ENV=production next start",
    "lint": "eslint . && node scripts/check-api-telemetry-coverage.js",
    "test": "jest --runInBand src/tests/auth.service.test.ts src/tests/club.service.test.ts src/tests/profile.service.test.ts src/tests/oac-mmr.service.test.ts src/tests/tournament-paywall.test.ts src/tests/simple-tournament-lifecycle.test.ts",
    "test:qa:unit": "jest --runInBand --forceExit src/tests/*.action.test.ts src/tests/*.lib.test.ts src/tests/withTelemetry.guard-failure.test.ts src/tests/withRouteTelemetry.test.ts src/tests/eligibility.paid-override.test.ts src/tests/create-player.action.guard.test.ts",
    "test:qa:coverage": "jest --runInBand --forceExit --coverage --collectCoverageFrom='src/features/auth/lib/authorizeUser.ts' --collectCoverageFrom='src/features/flags/lib/eligibility.ts' --collectCoverageFrom='src/shared/lib/withTelemetry.ts' --collectCoverageFrom='src/shared/lib/guards/result.ts' --collectCoverageFrom='src/features/auth/actions/index.ts' --collectCoverageFrom='src/features/subscription/actions/checkSubscription.action.ts' --collectCoverageFrom='src/features/feature-flags/actions/checkFeatureFlags.action.ts' src/tests/*.action.test.ts src/tests/*.lib.test.ts src/tests/withTelemetry.guard-failure.test.ts src/tests/withRouteTelemetry.test.ts src/tests/eligibility.paid-override.test.ts src/tests/create-player.action.guard.test.ts",
    "test:qa:e2e": "playwright test",
    "test:qa:load": "pnpm test:load",
    "test:load:run": "artillery run src/features/tests/load/load-test.yaml --output src/features/tests/load/results.json",
    "test:load:run:browse": "artillery run src/features/tests/load/load-test-browse.yaml --output src/features/tests/load/results.json",
    "test:load:run:lifecycle": "artillery run src/features/tests/load/load-test-lifecycle.yaml --output src/features/tests/load/results.json",
    "test:load:run:stress": "artillery run src/features/tests/load/load-test-stress.yaml --output src/features/tests/load/results.json",
    "test:load:summary": "node scripts/summarize-load-report.mjs src/features/tests/load/results.json",
    "test:load:analyze": "node scripts/analyze-load-report.mjs src/features/tests/load/results.json src/features/tests/load/analysis.md",
    "test:load:html": "node scripts/generate-load-html-report.mjs src/features/tests/load/results.json src/features/tests/load/summary.json src/features/tests/load/analysis.md src/features/tests/load/report.html",
    "test:load:index": "node scripts/generate-load-index-html.mjs src/features/tests/load/artifacts src/features/tests/load/artifacts/index.html",
    "test:load:diagnostics": "bash scripts/run-load-with-diagnostics.sh",
    "test:load:diagnostics:browse": "LOAD_TEST_PROFILE=browse bash scripts/run-load-with-diagnostics.sh",
    "test:load:diagnostics:lifecycle": "LOAD_TEST_PROFILE=lifecycle bash scripts/run-load-with-diagnostics.sh",
    "test:load:diagnostics:stress": "LOAD_TEST_PROFILE=stress bash scripts/run-load-with-diagnostics.sh",
    "perf:baseline:timeout": "node scripts/capture-timeout-baseline.mjs",
    "perf:compare:timeout": "node scripts/compare-timeout-artifacts.mjs",
    "perf:verify:timeout": "bash scripts/verify-timeout-remediation.sh",
    "telemetry:reset:v3": "node scripts/reset-telemetry-v3.mjs",
    "test:load": "pnpm test:load:run && pnpm test:load:summary",
    "backfill:locations": "npx tsx scripts/backfill-structured-locations.ts",
    "backfill:first-nine-avg": "npx tsx scripts/backfill-first-nine-avg.ts",
    "backfill:match-averages": "npx tsx scripts/backfill-match-averages.ts",
    "recalc:oac-mmr": "npx tsx scripts/recalculate-oac-mmr.ts",
    "overwrite:emails": "npx tsx scripts/overwrite-email-templates.ts"
  },
