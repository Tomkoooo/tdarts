{
  "name": "@tdarts/api",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured'",
    "dev": "node --import tsx/esm src/trpc/standalone/server.ts",
    "start": "node dist/server.mjs",
    "test": "jest --config jest.config.cjs --runInBand --forceExit --passWithNoTests",
    "generate:openapi": "node --import tsx/esm src/trpc/openapi/generate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@tdarts/core": "workspace:*",
    "@tdarts/schemas": "workspace:*",
    "@tdarts/services": "workspace:*",
    "@trpc/openapi": "11.16.0-alpha",
    "@trpc/server": "^11.16.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "hono": "^4.12.10",
    "superjson": "^2.2.6",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@trpc/client": "^11.16.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.4",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^5"
  },
  "exports": {
    ".": "./src/index.ts",
    "./rest-handlers": "./src/rest-handlers-entry.ts"
  }
}
