#!/usr/bin/env sh

set -e

echo "🚀 Running pre-push checks..."
echo "⏳ This may take a few minutes..."

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT" || exit 1

PNPM_BIN="$(command -v pnpm || true)"
if [ -z "$PNPM_BIN" ]; then
  echo "❌ pnpm not found on PATH inside pre-push hook."
  echo "Install pnpm (https://pnpm.io/installation) and try again."
  exit 1
fi

echo "🔧 pnpm: $($PNPM_BIN -v)"

echo ""
echo "🏗️  Running production build (web)..."
"$PNPM_BIN" run build:web || {
  echo ""
  echo "❌ Build failed. Please fix the errors before pushing."
  echo "Run 'pnpm run build:web' to see the errors."
  exit 1
}

echo ""
echo "✅ All pre-push checks passed! Proceeding with push..."
echo ""
